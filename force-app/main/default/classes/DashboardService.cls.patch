--- force-app/main/default/classes/DashboardService.cls
+++ force-app/main/default/classes/DashboardService.cls
@@ -648,7 +648,9 @@
             'recentQuotes' => getMyRecentQuotes(),
             'actionItems' => getPendingActionItems(),
             'topProducts' => getMyTopProducts(),
-            'topTransactions' => getMyTopTransactions()
+            'topTransactions' => getMyTopTransactions(),
+            'catalogDiscounts' => getCatalogDiscounts(),
+            'productFeeds' => getProductFeeds()
         };
     }
+
+    private List<Map<String, Object>> getCatalogDiscounts() {
+        List<Map<String, Object>> discounts = new List<Map<String, Object>>();
+        try {
+            for (Discount_Tier__c dt : [
+                SELECT Id, Discount_Percent__c, Lower_Bound__c, Upper_Bound__c, Product__r.Name 
+                FROM Discount_Tier__c 
+                ORDER BY CreatedDate DESC 
+                LIMIT 3
+            ]) {
+                String title = dt.Product__r != null ? dt.Product__r.Name : 'Product';
+                String text = 'Discount ' + dt.Discount_Percent__c + '% on ' + dt.Lower_Bound__c + '-' + dt.Upper_Bound__c + ' items of ' + title;
+                discounts.add(new Map<String, Object>{
+                    'id' => dt.Id,
+                    'title' => dt.Product__r != null ? dt.Product__r.Name : 'Volume Discount',
+                    'text' => text,
+                    'val' => '-' + dt.Discount_Percent__c + '%'
+                });
+            }
+        } catch(Exception e) {}
+        return discounts;
+    }
+
+    private List<Map<String, Object>> getProductFeeds() {
+        List<Map<String, Object>> feeds = new List<Map<String, Object>>();
+        try {
+            // Latest Product
+            List<Product__c> prods = [SELECT Id, Name FROM Product__c ORDER BY CreatedDate DESC LIMIT 1];
+            if (!prods.isEmpty()) {
+                feeds.add(new Map<String, Object>{
+                    'id' => prods[0].Id,
+                    'tag' => 'New Release',
+                    'tagClass' => 'feed-tag blue',
+                    'title' => prods[0].Name,
+                    'desc' => 'New Product ' + prods[0].Name + ' added',
+                    'icon' => 'utility:favorite'
+                });
+            }
+            // Latest Resource Role
+            List<Resource_Role__c> roles = [SELECT Id, Name FROM Resource_Role__c ORDER BY CreatedDate DESC LIMIT 1];
+            if (!roles.isEmpty()) {
+                feeds.add(new Map<String, Object>{
+                    'id' => roles[0].Id,
+                    'tag' => 'Resource',
+                    'tagClass' => 'feed-tag green',
+                    'title' => roles[0].Name,
+                    'desc' => 'New Resource Role ' + roles[0].Name + ' added',
+                    'icon' => 'utility:user'
+                });
+            }
+            // Latest Add On
+            List<Add_On__c> addons = [SELECT Id, Name FROM Add_On__c ORDER BY CreatedDate DESC LIMIT 1];
+            if (!addons.isEmpty()) {
+                feeds.add(new Map<String, Object>{
+                    'id' => addons[0].Id,
+                    'tag' => 'Add-On',
+                    'tagClass' => 'feed-tag orange',
+                    'title' => addons[0].Name,
+                    'desc' => 'New Add-On ' + addons[0].Name + ' added',
+                    'icon' => 'utility:puzzle'
+                });
+            }
+        } catch(Exception e) {}
+        return feeds;
+    }
 }
