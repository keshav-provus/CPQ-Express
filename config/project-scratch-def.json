{
  "orgName": "CPQ Express Dev Org",
  "edition": "enterprise",
  "description": "Scratch org for CPQ Express — custom Salesforce CPQ with Apex service layer, LWC components, role-based access control, approval workflows, CSV import, phase-based quoting, and AI features (Einstein + Agentforce).",

  "features": [
    "EnableSetPasswordInApi",
    "AddCustomApps:10",
    "Einstein1AIPlatform",
    "EinsteinSearch",
    "Chatbot",
    "Knowledge",
    "ServiceCloud",
    "SalesCloudEinstein",
    "SalesforceHostedMCP"
  ],

  "settings": {
    "lightningExperienceSettings": {
      "enableS1DesktopEnabled": true
    },
    "mobileSettings": {
      "enableS1EncryptedStoragePref2": false
    },
    "securitySettings": {
      "sessionSettings": {
        "enableClickjackNonsetupSFDC": true,
        "enableClickjackNonsetupUser": true,
        "enableClickjackNonsetupUserHeaderless": true,
        "enableClickjackSetup": true
      }
    },
    "apexSettings": {
      "enableAggregateCodeCoverageOnly": false,
      "enableDisableParallelApexTesting": false,
      "enableGaplessTestAutoNum": false
    },
    "chatterSettings": {
      "enableChatter": false
    },
    "emailAdministrationSettings": {
      "enableEnhancedEmailEnabled": true
    },
    "userManagementSettings": {
      "enableEnhancedPermsetMgmt": true
    },
    "recordPageSettings": {
      "enableActivityRelatedList": true
    },
    "contentSettings": {
      "enableContent": true
    },
    "knowledgeSettings": {
      "enableKnowledge": true
    },
    "einsteinGptSettings": {
      "enableEinsteinGptPlatform": true
    }
  }
}